# adv-data-comp is fully functional with ZERO environment variables — every
# comparison layer and every output format works without any of these set.
# They're only needed for the optional --explain (LLM) feature and to tune
# defaults that also have CLI-flag equivalents.

# Engine selection threshold (combined file size, MB). Same as
# --memory-threshold-mb; the CLI flag overrides this if both are set.
ADV_DATA_COMP_MEMORY_THRESHOLD_MB=500

# --- LLM explanation feature (--explain), opt-in -----------------------------
# Portkey account API key.
PORTKEY_API_KEY=pk-your-portkey-api-key

# Portkey Prompt Library prompt ID used to generate anomaly explanations.
# If unset, --explain prints a warning and the run continues without
# explanations rather than failing.
PORTKEY_PROMPT_EXPLAIN_ID=pp-your-prompt-id
